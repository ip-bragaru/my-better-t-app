{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "generate:tokens": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "tokens/design-tokens.json",
        "scripts/generate-design-tokens.mjs"
      ],
      "outputs": [
        "styles/theme.css",
        "src/shared/config/design-tokens.generated.ts",
        "src/shared/config/fonts.ts"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
